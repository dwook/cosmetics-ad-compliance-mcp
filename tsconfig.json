{
  "compilerOptions": {
    "target": "ES2021",
    "module": "ES2020",
    "moduleResolution": "node",
    "lib": ["ES2021"],
    "strict": true,
    "rootDir": ".",
    "outDir": "dist",
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": [
    "types/**/*.d.ts",
    "packages/**/*.ts",
    "tests/**/*.ts"
  ]
}
